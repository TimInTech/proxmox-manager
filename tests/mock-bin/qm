#!/usr/bin/env bash
set -euo pipefail

cmd="${1:-}"
shift || true

case "$cmd" in
  list)
    cat <<'EOL'
VMID NAME STATUS MEM(MB) BOOTDISK(GB) PID
200 vm-one running 1024 10.00 1234
201 - stopped 1024 10.00 0
EOL
    ;;
  agent)
    if [[ "${2:-}" == "network-get-interfaces" ]]; then
      cat <<'EOL'
{"result":[{"name":"eth0","hardware-address":"52:54:00:aa:bb:cc","ip-addresses":[{"ip-address-type":"ipv4","ip-address":"192.168.178.20"},{"ip-address-type":"ipv6","ip-address":"fe80::1"}]},{"name":"eth1","ip-addresses":[{"ip-address-type":"ipv4","ip-address":"10.10.10.5"}]}]}
EOL
    fi
    ;;
  config)
    case "${1:-}" in
      201) echo "name: vm-fallback" ;;
      *) echo "name: vm-${1:-unknown}" ;;
    esac
    ;;
  status)
    echo "status: running"
    ;;
  *)
    exit 0
    ;;
esac
